{
  "Statement": [
    {
      "Action": "sns:Publish",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "${AWS_ACCOUNT}"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:${AWS::Partition}:s3:::${BUCKET_NAME}"
        }
      },
      "Effect": "Allow",
      "Principal": {
        "Service": "s3.amazonaws.com"
      },
      "Resource": "arn:${AWS::Partition}:sns:${AWS_REGION}:${AWS_ACCOUNT}:${SNS_TOPIC_NAME}"
    }
  ],
  "Version": "2008-10-17"
}